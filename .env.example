# Database
DATABASE_URL=postgresql://constel:constel123@localhost:5432/constel_nextgen?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API
API_PORT=4000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# AI - Qwen (DashScope) - Use Singapore endpoint for India/international
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
AI_PROVIDER=qwen

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Constel AI NextGen <noreply@constel.ai>

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=

# Payment
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Code Execution
CODE_EXECUTION_TIMEOUT=10000
CODE_EXECUTION_MEMORY=128m
DOCKER_SANDBOX_IMAGE=constel-python-sandbox:latest

# Redis (for queues & caching)
REDIS_URL=redis://localhost:6379

# App
NEXT_PUBLIC_APP_NAME=Mantra.ai
NEXT_PUBLIC_COMPANY_NAME=Constel Global India Pvt. Ltd.
NEXT_PUBLIC_APP_URL=https://learn.mantraai.cloud
NEXT_PUBLIC_MARKETING_URL=https://mantra.ai
